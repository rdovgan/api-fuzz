# ── Target ────────────────────────────────────────────────────────────────
# OpenAPI 3.0 document: either a URL (Spring: usually /v3/api-docs) or a local
# JSON/YAML file path, e.g. SPEC_URL=./my-api-spec.yaml
SPEC_URL=http://host.docker.internal:8080/v3/api-docs
# Base URL of the running service under test
TARGET_URL=http://host.docker.internal:8080
# Auth header name + value applied to every request (leave TARGET_AUTH empty if none)
TARGET_AUTH_HEADER=Authorization
TARGET_AUTH=Bearer replace-me

# ── AI fuzzer (Z.ai GLM, via the Anthropic-Messages-compatible endpoint) ───
ANTHROPIC_API_KEY=your-zai-api-key
FUZZ_MODEL=glm-5.2
# Anthropic-compatible base URL. Defaults to Z.ai; override only to point at a
# different Anthropic-compatible provider (e.g. real Anthropic).
ANTHROPIC_BASE_URL=https://api.z.ai/api/anthropic
FUZZ_MAX_PAYLOADS_PER_PARAM=12
# What severity should make the AI layer exit non-zero: fail | warn | never
AI_FAIL_ON=fail

# ── Schemathesis ────────────────────────────────────────────────────────────
# Examples generated per parameter (higher = more thorough, slower)
STH_EXAMPLES=150

# Notes:
# - On Linux, host.docker.internal needs:  extra_hosts or --add-host, or use the
#   host's LAN IP / a shared docker network with your app.
# - Everything is driven by the spec; switching to a different API = change
#   SPEC_URL/TARGET_URL only. No per-endpoint config.
